'''
This is an example of the scripts needed to optimize hyperparameters of each
model at each predictor subset size. You'd need to change the inputs/outputs
depending on perspective "P" (3 options), algorithms (5 options) "A" and impact
category "IC" (3 options). In total 45 scripts as such need to be run.
'''
import pandas as pd
import numpy as np
import pickle
from tqdm import tqdm
from sklearn.ensemble import RandomForestRegressor, HistGradientBoostingRegressor
from sklearn.linear_model import Ridge
from sklearn.model_selection import cross_validate, GroupKFold
from sklearn.neural_network import MLPRegressor
from sklearn.neighbors import KNeighborsRegressor
import optuna
from sklearn.preprocessing import MinMaxScaler, PowerTransformer, PowerTransformer
from sklearn.preprocessing import OrdinalEncoder
from sklearn.pipeline import Pipeline
np.random.seed(12)

x_train = pd.read_pickle('x_P_wcat.pkl')
y_train = pd.read_pickle('y_P_wcat.pkl')
df_impacts = pd.read_pickle('df_impacts_P.pkl')
df_categorical = pd.read_pickle('df_categorical_P.pkl')
df_numerical = pd.read_pickle('df_inputs_P.pkl')
models = {'RF' : RandomForestRegressor(n_jobs = 1, random_state=12),
            'KNN' : KNeighborsRegressor(n_jobs=1),
            'ANN' : MLPRegressor(random_state=12, max_iter=10000),
            'GBM' : HistGradientBoostingRegressor(random_state = 12), 
            'GLM' : Ridge() }
            
best_estimators = {key: {model:{} for model in models.keys()} for key in df_impacts.columns}
estimators = models.keys()
groups = df_categorical.loc[x_train.index][['crop']]
enc = OrdinalEncoder()
groups_encoded = enc.fit_transform(groups)
cv = GroupKFold(n_splits = 5, shuffle = True, random_state = 12)
splits = cv.split(x_train , y_train, groups_encoded)
list_subset_sizes = list(np.arange(1,17))
transformer = PowerTransformer()

with open('dict_predictor_importances_P_IC_A_wcat.pkl', 'rb') as g:  
    best_estimators = pickle.load(g)


def objective_with_importances(trial, subset_size):
    n_features = x_train.shape[1] - x_train.columns.str.contains('KG_').sum() + 1

    if subset_size not in best_estimators[impact][estimator_name]:
        return float("-inf")
    best_subset = best_estimators[impact][estimator_name][subset_size]

    # Convert selected subset into a boolean mask
    feature_mask = [i in best_subset for i in range(n_features)]
    if feature_mask[-1] == True:
        feature_mask = feature_mask + [True, True, True]
    else:
        feature_mask = feature_mask + [False, False, False]
    x_train_subset = x_train.iloc[:, feature_mask].copy()

    if x_train_subset.columns.str.contains('KG_').sum() > 0:
        df_addition = x_train.iloc[:, x_train.columns.str.contains('KG_')]
        cols_to_use = df_addition.columns.difference(x_train_subset.columns)
        x_train_subset = pd.merge(x_train_subset, df_addition[cols_to_use], left_index=True, right_index=True, how='outer')

    if estimator_name == "RF":
        n_estimators = trial.suggest_int('n_estimators', 50, 1000, log=True)
        criterion = trial.suggest_categorical('criterion', ['squared_error', 'absolute_error', 'friedman_mse'])
        min_samples_leaf = trial.suggest_int('min_samples_leaf', 1, 10)
        max_features = trial.suggest_float('max_features', 0.2, 1, step=0.05)
        max_samples = trial.suggest_float('max_samples', 0.5, 1, step=0.1)
        
        classifier_obj = RandomForestRegressor(n_estimators=n_estimators, max_depth=None, criterion=criterion, min_samples_leaf=min_samples_leaf, max_samples=max_samples, n_jobs=-1, random_state=12, max_features=max_features)

    elif estimator_name == "KNN":
        n_neighbors = trial.suggest_int('n_neighbors', 3, 100)
        weights = trial.suggest_categorical('weights', ['uniform', 'distance'])
        p = trial.suggest_float('p', 1, 5, step=0.1)
        leaf_size = trial.suggest_int('leaf_size', 10, 50)

        classifier_obj = KNeighborsRegressor(n_neighbors=n_neighbors, weights=weights, leaf_size=leaf_size, p=p, n_jobs=-1)
    
    elif estimator_name == "GBM":
        learning_rate = trial.suggest_float('learning_rate', 0.1, 1, step = 0.05)
        loss = trial.suggest_categorical('loss', ['squared_error', 'absolute_error'])
        max_features = trial.suggest_float('max_features', 0.5, 1, step=0.1)
        min_samples_leaf = trial.suggest_int('min_samples_leaf', 5, 25)
        max_leaf_nodes = trial.suggest_int('max_leaf_nodes', 20, 40)
        l2_regularization = trial.suggest_float('l2_regularization', 0, 0.5, step = 0.1)
        max_iter = trial.suggest_int('max_iter', 100, 500, step=10)

        classifier_obj = HistGradientBoostingRegressor(learning_rate=learning_rate, loss=loss, max_features=max_features, 
                                                       max_iter=max_iter, min_samples_leaf=min_samples_leaf, max_leaf_nodes=max_leaf_nodes, l2_regularization=l2_regularization, random_state=12)

    elif estimator_name == "GLM":
        alpha = trial.suggest_float('alpha', 0, 10, step = 0.01)
        classifier_obj = Ridge(alpha=alpha, max_iter=10000)

    elif estimator_name == "ANN":
        num_layers = trial.suggest_int('num_layers', 1, 3)
        i = trial.suggest_int('i', 5, 100)
        j = trial.suggest_int('j', 5, 75) if num_layers >= 2 else None
        k = trial.suggest_int('k', 5, 50) if num_layers == 3 else None

        if num_layers == 1:
            hidden_layer_sizes = (i,)
        elif num_layers == 2:
            hidden_layer_sizes = (i, j)
        else:
            hidden_layer_sizes = (i, j, k)

        solver = trial.suggest_categorical('solver', ['sgd', 'adam'])
        activation = trial.suggest_categorical('activation', ['identity', 'logistic', 'tanh', 'relu'])
        alpha=trial.suggest_float('alpha', 0.00001, 0.1, log = True)

        classifier_obj = MLPRegressor(hidden_layer_sizes=hidden_layer_sizes, solver=solver, activation=activation, learning_rate=learning_rate, alpha=alpha, random_state=12, max_iter = 10000)
    
    pipeline = Pipeline([('transformer', transformer), ('scaler', MinMaxScaler((0, 1))), ('regressor', classifier_obj)  ])  

        
    score = cross_validate(pipeline, x_train_subset, y_train_impact, cv=cv, groups = groups_encoded,  scoring='neg_root_mean_squared_error', n_jobs=-1, return_train_score=False)['test_score'].mean()
    return score

tuned_estimators = {}
estimator_name = 'A'
impact = 'IC'

for subset_size in list_subset_sizes:
    y_train_impact = y_train[impact].copy()   

    study = optuna.create_study(direction="maximize", sampler=optuna.samplers.TPESampler(multivariate=True, n_startup_trials=2000, seed=12))
    study.optimize(lambda trial: objective_with_importances(trial, subset_size), n_trials=2020, n_jobs=-1)

    try:
        best_params = study.best_params
        if impact not in tuned_estimators:
            tuned_estimators[impact] = {}
        if estimator_name not in tuned_estimators[impact]:
            tuned_estimators[impact][estimator_name] = {}
        tuned_estimators[impact][estimator_name][subset_size] = best_params

        print(f"Saved results for Impact={impact}, Estimator={estimator_name}, Subset Size={subset_size}")

    except Exception as e:
        print(f"Optuna failed for Impact={impact}, Estimator={estimator_name}, Subset Size={subset_size}. Error: {e}")

with open('dict_tuned_estimators_P_IC_A_wcat.pkl', 'wb') as f:
    pickle.dump(tuned_estimators, f)